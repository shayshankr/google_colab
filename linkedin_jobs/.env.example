# LinkedIn Job Application System Configuration

# Flask Configuration
SECRET_KEY=linkedin_job_app_secret_key_12345
DEBUG=True
PORT=5001

# LinkedIn API Configuration (if you plan to use real LinkedIn integration)
# LINKEDIN_CLIENT_ID=your_linkedin_client_id
# LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
# LINKEDIN_REDIRECT_URI=http://localhost:5001/auth/linkedin/callback

# Search Rate Limiting (to respect LinkedIn's terms of service)
SEARCH_RATE_LIMIT_PER_MINUTE=10
APPLICATION_RATE_LIMIT_PER_HOUR=50

# Demo Mode Settings
DEMO_MODE=True
MOCK_JOB_RESULTS=True

# Database Configuration (for production use)
# DATABASE_URL=sqlite:///linkedin_jobs.db
# or
# DATABASE_URL=postgresql://user:password@localhost/linkedin_jobs